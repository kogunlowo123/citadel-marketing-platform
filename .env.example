# Database
POSTGRES_USER=citadel
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=citadel_marketing
DATABASE_URL=postgresql+asyncpg://citadel:changeme_in_production@postgres:5432/citadel_marketing

# Redis
REDIS_URL=redis://redis:6379/0

# Resend (email delivery)
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=noreply@mail.citadelcloudmanagement.com
RESEND_FROM_NAME=Citadel Cloud Management

# AI (Claude API for content generation)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# App
APP_SECRET_KEY=generate_a_secure_random_key_here
APP_ENV=development
APP_URL=http://localhost
FRONTEND_URL=http://localhost:3000

# Rate limiting
SEND_RATE_PER_MINUTE=60
MAX_DAILY_SENDS=5000

# Compliance
UNSUBSCRIBE_BASE_URL=http://localhost/unsubscribe
COMPANY_NAME=Citadel Cloud Management
COMPANY_ADDRESS=United States
